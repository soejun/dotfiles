{
  "layer": "top",
  "position": "top",
  "modules-left": [
    "sway/window"
  ],
  "modules-center": [
    "sway/mode"
  ],
  "modules-right": [
    "sway/workspaces",
    "cpu",
    "memory",
    "pulseaudio",
    "network",
    "battery",
    "clock",
    "custom/notification"
  ],
  "height": 24,
  "sway/window": {
    "icon": false,
    "icon-size": 16,
    "format": "<span size=\"medium\" font_weight=\"600\">{}</span>",
    "max-length": 1000
  },
  "sway/workspaces": {
    "current-only": false,
    "all-outputs": false,
    // "format": "{icon}"
    "format": "<span size=\"medium\" font_weight=\"600\">{name}</span>"
  },
  "sway/mode": {
    "format": "<span size=\"medium\" font_weight=\"800\">{}</span>"
  },
  "tray": {
    "icon-size": 12,
    "spacing": 10
  },
  "cpu": {
    "interval": 1,
    "format": "<span font_weight=\"500\">CPU: {usage}%</span>",
    "max-length": 10
  },
  "memory": {
    "interval": 1,
    "format": "<span font_weight=\"500\">MEMORY: {percentage}%</span>",
    "max-length": 15
  },
  "pulseaudio": {
    //"scroll-step": 1,
    "format": "<span size=\"medium\">{icon}</span>",
    "format-bluetooth": "{icon}ΎΛΦ",
    "format-muted": "ΎΑο",
    "format-icons": {
      "headphones": "ΎΑξ",
      "handsfree": "ΎΨΡ",
      "headset": "ΎΨΡ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": [
        "ΎΑπ",
        "ΎΑρ"
      ]
    },
    "on-click": "pavucontrol"
  },
  "network": {
    "format-wifi": "<span size=\"medium\" >{icon}</span>",
    "format-ethernet": "<span size=\"medium\" >ΎΔΒ</span>",
    "format-disconnected": "<span size=\"medium\" color=\"#E06C75\">ΎΕπ</span>",
    "max-length": 50,
    "on-click": "kitty -e 'nmtui'",
    "format-icons": [
      "≤░νψ",
      "≤░νθ",
      "≤░νλ",
      "≤░νξ",
      "≤░νρ"
    ]
  },
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 20
    },
    "format": "{icon}",
    "format-charging": "<span>ΎΘο {capacity}%</span>",
    "format-plugged": "<span >ΎΘο {capacity}%</span>",
    "format-alt": "{time} {icon}",
    "format-icons": [
      "ΎΚΕ",
      "ΎΚΔ",
      "ΎΚΓ",
      "ΎΚΒ",
      "ΎΚΑ"
    ]
  },
  "clock": {
    "format": "<span font_weight=\"600\">{:%a %b. %d %I:%M %p}</span>"
  },
  "custom/notification": {
    "tooltip": true,
    "format": "{icon}",
    "format-icons": {
      "notification": "≤▒Ζτ",
      "none": "≤░Γε",
      "dnd-notification": "≤░Γι",
      "dnd-none": "≤░ςΥ",
      "inhibited-notification": "≤░Γδ",
      "inhibited-none": "≤░ςΣ",
      "dnd-inhibited-notification": "≤░Γδ",
      "dnd-inhibited-none": "≤░ςΣ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  }
}
